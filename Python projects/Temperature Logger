import time
import os
import csv

User_Input = float(input("Enter the temperature reading: "))
log = [(0.0,User_Input)]

start_time = time.perf_counter()
while True:
    New_Temperature = (input("Enter the temperature reading (or type 'exit' to finish): "))
    if New_Temperature.lower() == 'exit':
        print (log)
        break
    
    try:
        log.append((round(time.perf_counter() - start_time, 2),float(New_Temperature)))

    except ValueError:
        print("Invalid input. Please enter a numeric value for temperature or 'exit' to finish.")

csv_filename = str(input("Please enter a file name: "))


if os.path.isfile(csv_filename):
    print(
        f"Error: The file '{csv_filename}' already exists. Data was not exported to prevent overwriting."
    )
else:
    try:
        with open(csv_filename, "w", newline="", encoding="utf-8") as file:
            csv_writer = csv.writer(file)
    
     
            csv_writer.writerow(["Elapsed_Time", "Temperature"])
            csv_writer.writerows(log)

        print(f"Success! Data exported to {csv_filename}")

    except OSError as e:
        print(f"Error: Could not write file due to a system error: {e}")
        